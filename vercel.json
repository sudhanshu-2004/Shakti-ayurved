{
  "version": 2,
  "rewrites": [
    {
      "source": "/crm-api/(.*)",
      "destination": "/crm-api/api/index.js"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/crm/(.*)",
      "destination": "/crm-frontend/$1"
    },
    {
      "source": "/crm",
      "destination": "/crm-frontend/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/build/$1"
    }
  ]
}
